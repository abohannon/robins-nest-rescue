---
import ActionCard from "./ActionCard.astro";
import SectionHeader from "./SectionHeader.astro";

interface CardData {
  icon: string;
  title: string;
  description: string;
  linkHref: string;
  linkLabel: string;
}

interface Props {
  overline?: string;
  heading?: string;
  subheading?: string;
  cards: CardData[];
}

const { overline, heading, subheading, cards } = Astro.props;
const hasHeader = !!(overline || heading || subheading);
---

<section class="bg-off-white px-6 py-16">
  <div class="mx-auto max-w-5xl">
    {
      hasHeader && (
        <SectionHeader
          overline={overline}
          heading={heading}
          subheading={subheading}
        />
      )
    }
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {cards.map((card) => <ActionCard {...card} />)}
    </div>
  </div>
</section>
