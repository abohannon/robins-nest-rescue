---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  id: string;
  name: string;
  images: ImageMetadata[];
}

const { id, name, images } = Astro.props;
const labelId = `${id}-label`;
---

<dialog
  id={id}
  aria-labelledby={labelId}
  data-lightbox
  data-lightbox-count={images.length}
  class="fixed inset-0 m-0 h-full max-h-none w-full max-w-none bg-black/90 p-0 backdrop:bg-black/90"
>
  <h2 id={labelId} class="sr-only">{name} photo gallery</h2>

  <button
    type="button"
    aria-label="Close gallery"
    data-lightbox-close
    class="absolute top-4 right-4 z-20 cursor-pointer rounded-full bg-white/10 p-2 text-2xl leading-none text-white transition-colors hover:bg-white/20 focus-visible:ring-2 focus-visible:ring-white focus-visible:outline-none"
  >
    <span aria-hidden="true">✕</span>
  </button>

  {
    images.length > 1 && (
      <>
        <button
          type="button"
          aria-label="Previous image"
          data-lightbox-prev
          class="absolute top-1/2 left-4 z-20 -translate-y-1/2 cursor-pointer rounded-full bg-white/10 p-3 text-2xl leading-none text-white transition-colors hover:bg-white/20 focus-visible:ring-2 focus-visible:ring-white focus-visible:outline-none"
        >
          <span aria-hidden="true">‹</span>
        </button>
        <button
          type="button"
          aria-label="Next image"
          data-lightbox-next
          class="absolute top-1/2 right-4 z-20 -translate-y-1/2 cursor-pointer rounded-full bg-white/10 p-3 text-2xl leading-none text-white transition-colors hover:bg-white/20 focus-visible:ring-2 focus-visible:ring-white focus-visible:outline-none"
        >
          <span aria-hidden="true">›</span>
        </button>
        <div
          data-lightbox-counter
          aria-live="polite"
          class="absolute bottom-6 left-1/2 z-20 -translate-x-1/2 rounded-full bg-white/10 px-4 py-1 text-sm text-white"
        >
          1 / {images.length}
        </div>
      </>
    )
  }

  <div class="flex h-full w-full items-center justify-center p-6">
    {
      images.map((img, i) => (
        <Image
          src={img}
          alt={`${name} — photo ${i + 1}`}
          data-lightbox-image
          data-lightbox-image-index={i}
          widths={[640, 1024, 1440, 1920]}
          sizes="100vw"
          class:list={[
            "max-h-[90vh] max-w-[90vw] object-contain",
            i === 0 ? "" : "hidden",
          ]}
        />
      ))
    }
  </div>
</dialog>

<script>
  document
    .querySelectorAll<HTMLDialogElement>("dialog[data-lightbox]")
    .forEach((dialog) => {
      const count = Number(dialog.dataset.lightboxCount ?? "0");
      if (count === 0) return;

      const images = dialog.querySelectorAll<HTMLImageElement>(
        "[data-lightbox-image]",
      );
      const counter = dialog.querySelector<HTMLElement>(
        "[data-lightbox-counter]",
      );
      let current = 0;

      const show = (index: number) => {
        current = ((index % count) + count) % count;
        images.forEach((img, i) => {
          img.classList.toggle("hidden", i !== current);
        });
        if (counter) {
          counter.textContent = `${current + 1} / ${count}`;
        }
      };

      // Triggers: anything with data-lightbox-target matching this dialog's id
      document
        .querySelectorAll<HTMLElement>(`[data-lightbox-target="${dialog.id}"]`)
        .forEach((trigger) => {
          trigger.addEventListener("click", () => {
            const i = Number(trigger.dataset.lightboxIndex ?? "0");
            show(i);
            if (!dialog.open) {
              dialog.showModal();
              document.body.style.overflow = "hidden";
            }
          });
        });

      dialog
        .querySelector<HTMLElement>("[data-lightbox-close]")
        ?.addEventListener("click", () => dialog.close());

      dialog
        .querySelector<HTMLElement>("[data-lightbox-prev]")
        ?.addEventListener("click", () => show(current - 1));

      dialog
        .querySelector<HTMLElement>("[data-lightbox-next]")
        ?.addEventListener("click", () => show(current + 1));

      // Backdrop click closes
      dialog.addEventListener("click", (e) => {
        if (e.target === dialog) dialog.close();
      });

      dialog.addEventListener("close", () => {
        document.body.style.overflow = "";
      });

      dialog.addEventListener("keydown", (e) => {
        if (e.key === "ArrowLeft") {
          e.preventDefault();
          show(current - 1);
        } else if (e.key === "ArrowRight") {
          e.preventDefault();
          show(current + 1);
        }
      });
    });
</script>
