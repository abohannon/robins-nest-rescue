---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import AnimalGalleryLightbox from "./AnimalGalleryLightbox.astro";

interface Props {
  photo: ImageMetadata;
  gallery?: ImageMetadata[];
  name: string;
}

const { photo, gallery, name } = Astro.props;

const images: ImageMetadata[] =
  gallery && gallery.length > 0 ? gallery : [photo];

const lightboxId = "animal-gallery-lightbox";
---

{
  images.length === 1 ? (
    <button
      type="button"
      data-lightbox-target={lightboxId}
      data-lightbox-index="0"
      aria-label={`View larger photo of ${name}`}
      class="relative block h-[400px] w-full cursor-zoom-in overflow-hidden rounded-lg focus-visible:ring-2 focus-visible:ring-teal-500 focus-visible:ring-offset-2 focus-visible:outline-none"
    >
      <Image
        src={images[0]}
        alt=""
        aria-hidden="true"
        class="absolute inset-0 h-full w-full scale-110 object-cover blur-2xl brightness-90"
        widths={[640, 1024]}
        sizes="(max-width: 768px) 100vw, 1024px"
      />
      <Image
        src={images[0]}
        alt={name}
        class="relative z-10 h-full w-full object-contain"
        widths={[640, 1024, 1440]}
        sizes="(max-width: 768px) 100vw, 1024px"
      />
    </button>
  ) : (
    <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
      {images.map((img, i) => (
        <button
          type="button"
          data-lightbox-target={lightboxId}
          data-lightbox-index={i}
          aria-label={`View ${name} photo ${i + 1} of ${images.length}`}
          class="group relative block aspect-square cursor-zoom-in overflow-hidden rounded-lg focus-visible:ring-2 focus-visible:ring-teal-500 focus-visible:ring-offset-2 focus-visible:outline-none"
        >
          <Image
            src={img}
            alt={`${name} — photo ${i + 1}`}
            class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
            widths={[320, 480, 640]}
            sizes="(max-width: 768px) 50vw, 25vw"
          />
        </button>
      ))}
    </div>
  )
}

<AnimalGalleryLightbox id={lightboxId} name={name} images={images} />
