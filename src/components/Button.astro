---
interface Props {
  href: string;
  variant?: "primary" | "secondary" | "accent" | "ghost";
  size?: "sm" | "default";
  class?: string;
  target?: "_blank" | "_self" | "_parent" | "_top";
  rel?: string;
}

const {
  href,
  variant = "primary",
  size = "default",
  class: className,
  target,
  rel,
} = Astro.props;

const base =
  "inline-block rounded-md font-body font-semibold no-underline transition-colors";

const sizeStyles: Record<string, string> = {
  sm: "px-4 py-2 text-sm",
  default: "px-8 py-3",
};

const variantStyles: Record<string, string> = {
  primary: "bg-primary text-white hover:bg-primary-dark",
  secondary:
    "border-2 border-white bg-transparent text-white hover:bg-white/10",
  accent: "bg-accent text-white hover:bg-accent-dark",
  ghost: "bg-white text-primary hover:bg-off-white",
};

const computedRel =
  rel ?? (target === "_blank" ? "noopener noreferrer" : undefined);
---

<a
  href={href}
  class:list={[base, sizeStyles[size], variantStyles[variant], className]}
  target={target}
  rel={computedRel}
>
  <slot />
</a>
