---

---

<dialog
  id="donate-modal"
  aria-labelledby="donate-modal-title"
  class="m-auto w-full max-w-[500px] rounded-lg bg-white p-0 shadow-xl backdrop:bg-black/50 open:flex open:flex-col"
>
  <div class="flex items-center justify-end p-4 pb-0">
    <h2 id="donate-modal-title" class="sr-only">Donate</h2>
    <button
      type="button"
      id="donate-modal-close"
      aria-label="Close donation form"
      class="cursor-pointer border-none bg-transparent p-1 text-2xl leading-none text-neutral-500 hover:text-neutral-800"
    >
      ✕
    </button>
  </div>
  <div class="px-6 pb-6">
    <givebutter-widget id="LvQX0j"></givebutter-widget>
  </div>
</dialog>

<script>
  const dialog = document.getElementById(
    "donate-modal",
  ) as HTMLDialogElement | null;
  const closeBtn = document.getElementById("donate-modal-close");

  document.addEventListener("donate:open", () => {
    if (dialog && !dialog.open) {
      dialog.showModal();
      document.body.style.overflow = "hidden";
    }
  });

  closeBtn?.addEventListener("click", () => {
    dialog?.close();
  });

  dialog?.addEventListener("click", (e) => {
    if (e.target === dialog) {
      dialog.close();
    }
  });

  dialog?.addEventListener("close", () => {
    document.body.style.overflow = "";
  });
</script>
