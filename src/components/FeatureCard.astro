---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  description: string;
  href: string;
  image?: ImageMetadata;
  placeholderColor?: string;
}

const {
  title,
  description,
  href,
  image,
  placeholderColor = "bg-primary",
} = Astro.props;
---

<a
  href={href}
  class="group border-border block overflow-hidden rounded-lg border bg-white no-underline transition-shadow hover:shadow-lg"
>
  <div
    class:list={[
      "relative h-48 w-full overflow-hidden",
      !image && placeholderColor,
    ]}
  >
    {
      image ? (
        <Image
          src={image}
          alt=""
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
          widths={[400, 600]}
          sizes="(max-width: 640px) 100vw, 33vw"
        />
      ) : (
        <div class="absolute inset-0 flex items-center justify-center text-white/70">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-12 w-12"
            aria-hidden="true"
          >
            <rect x="3" y="4" width="18" height="16" rx="2" />
            <circle cx="9" cy="10" r="1.5" />
            <path d="m21 16-5-5L5 20" />
          </svg>
          <span class="sr-only">Photo coming soon</span>
        </div>
      )
    }
  </div>
  <div class="p-6">
    <h3 class="font-heading text-text group-hover:text-primary mb-2 text-xl">
      {title}
    </h3>
    <p class="font-body text-text-light text-sm leading-relaxed">
      {description}
    </p>
  </div>
</a>
