---
import FeatureCard from "./FeatureCard.astro";
import SectionHeader from "./SectionHeader.astro";
import type { ImageMetadata } from "astro";

interface CardData {
  title: string;
  description: string;
  href: string;
  image?: ImageMetadata;
  placeholderColor?: string;
}

interface Props {
  overline?: string;
  heading?: string;
  subheading?: string;
  cards: CardData[];
}

const { overline, heading, subheading, cards } = Astro.props;
const hasHeader = !!(overline || heading || subheading);
---

<section class="px-6 py-16">
  <div class="mx-auto max-w-5xl">
    {
      hasHeader && (
        <SectionHeader
          overline={overline}
          heading={heading}
          subheading={subheading}
        />
      )
    }
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {cards.map((card) => <FeatureCard {...card} />)}
    </div>
  </div>
</section>
