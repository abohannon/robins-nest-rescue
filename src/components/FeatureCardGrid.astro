---
import FeatureCard from './FeatureCard.astro';
import type { ImageMetadata } from 'astro';

interface CardData {
  title: string;
  description: string;
  href: string;
  image?: ImageMetadata;
  placeholderColor?: string;
}

interface Props {
  heading?: string;
  subheading?: string;
  cards: CardData[];
}

const { heading, subheading, cards } = Astro.props;
---

<section class="px-6 py-16">
  <div class="mx-auto max-w-5xl">
    {heading && (
      <div class="mb-10 text-center">
        <h2 class="mb-2 font-heading text-3xl text-text">{heading}</h2>
        {subheading && (
          <p class="font-body text-base text-text-light">{subheading}</p>
        )}
      </div>
    )}
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {cards.map((card) => (
        <FeatureCard {...card} />
      ))}
    </div>
  </div>
</section>
