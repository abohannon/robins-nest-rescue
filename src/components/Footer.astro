---
import { navLinks } from '../config/navigation';

const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-neutral-50 px-6 py-8">
  <div class="mx-auto flex max-w-5xl flex-col items-center gap-4 text-center">
    <nav class="flex flex-wrap justify-center gap-6">
      {navLinks.map(({ label, href }) => (
        <a
          href={href}
          class="font-body text-sm text-text-light no-underline hover:text-primary"
        >
          {label}
        </a>
      ))}
    </nav>
    <div class="flex flex-wrap justify-center gap-4 font-body text-sm text-text-light">
      <a
        href="mailto:info@robinsnestrescue.org"
        class="no-underline hover:text-primary"
      >
        info@robinsnestrescue.org
      </a>
    </div>
    <p class="font-body text-xs text-text-light opacity-70">
      &copy; {year} Robin's Nest Rescue. All rights reserved.
    </p>
  </div>
</footer>
