---
import Logo from './Logo.astro';
import { navLinks } from '../config/navigation';

const year = new Date().getFullYear();
---

<footer class="bg-primary-dark px-6 py-12 text-white">
  <div class="mx-auto flex max-w-5xl flex-col gap-8 md:flex-row md:items-start md:justify-between">
    <div>
      <Logo width={120} class="mb-2" variant="on-dark" />
      <p class="font-body text-sm opacity-70">
        &copy; {year} Robin's Nest Rescue. All rights reserved.
      </p>
    </div>
    <nav class="flex flex-wrap gap-6">
      {navLinks.map(({ label, href }) => (
        <a
          href={href}
          class="font-body text-sm text-white no-underline opacity-80 hover:opacity-100"
        >
          {label}
        </a>
      ))}
    </nav>
    <div class="font-body text-sm">
      <a
        href="mailto:info@robinsnestrescue.org"
        class="text-white no-underline opacity-80 hover:opacity-100"
      >
        info@robinsnestrescue.org
      </a>
    </div>
  </div>
</footer>
