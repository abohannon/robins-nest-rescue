---
import { navLinks } from "../config/navigation";

const year = new Date().getFullYear();
---

<footer class="border-border border-t bg-neutral-50 px-6 py-8">
  <div class="mx-auto flex max-w-5xl flex-col items-center gap-4 text-center">
    <nav class="flex flex-wrap justify-center gap-6">
      {
        navLinks.map(({ label, href }) => (
          <a
            href={href}
            class="font-body text-text-light hover:text-primary text-sm no-underline"
          >
            {label}
          </a>
        ))
      }
    </nav>
    <div
      class="font-body text-text-light flex flex-wrap justify-center gap-4 text-sm"
    >
      <a
        href="mailto:info@robinsnestrescue.org"
        class="hover:text-primary no-underline"
      >
        info@robinsnestrescue.org
      </a>
    </div>
    <div class="flex flex-col items-center gap-3">
      <p class="font-body text-text-light text-xs opacity-70">
        501(c)(3) Non-profit · FEIN 93-3888904
      </p>
      <a
        aria-label="Robin's Nest Rescue on Candid"
        href="https://app.candid.org/profile/15261949/robins-nest-rescue-93-3888904/?pkId=3079731d-7bae-4b38-b6b1-efdcfb684761"
        target="_blank"
        rel="noopener noreferrer"
      >
        <img
          alt=""
          src="https://widgets.guidestar.org/prod/v1/pdp/transparency-seal/15261949/svg"
          loading="lazy"
          class="w-24"
        />
      </a>
    </div>
    <p class="font-body text-text-light text-xs opacity-70">
      &copy; {year} Robin's Nest Rescue. All rights reserved.
    </p>
  </div>
</footer>
