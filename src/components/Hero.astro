---
interface Props {
  headline: string;
  subtext: string;
  primaryCta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  size?: 'default' | 'tall' | 'full';
}

const { headline, subtext, primaryCta, secondaryCta, size = 'default' } = Astro.props;

const sizeClasses: Record<'default' | 'tall' | 'full', string> = {
  default: 'px-6 py-16 md:py-24',
  tall: 'flex min-h-[70vh] items-center px-6',
  full: 'flex min-h-screen items-center px-6',
};
---

<section class:list={['bg-primary text-white', sizeClasses[size]]}>
  <div class="mx-auto max-w-5xl text-center">
    <h1 class="mb-4 font-heading text-3xl leading-tight md:text-5xl">
      {headline}
    </h1>
    <p class="mx-auto mb-8 max-w-xl text-lg leading-relaxed opacity-90">
      {subtext}
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a
        href={primaryCta.href}
        class="rounded-md bg-white px-8 py-3 font-body font-semibold text-primary no-underline hover:bg-off-white"
      >
        {primaryCta.label}
      </a>
      {secondaryCta && (
        <a
          href={secondaryCta.href}
          class="rounded-md border-2 border-white bg-transparent px-8 py-3 font-body font-semibold text-white no-underline hover:bg-white/10"
        >
          {secondaryCta.label}
        </a>
      )}
    </div>
  </div>
</section>
