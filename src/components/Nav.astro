---
import Logo from "./Logo.astro";
import Button from "./Button.astro";
import DonateButton from "./DonateButton.astro";
import { navLinks, navActions } from "../config/navigation";

interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;
---

<header class="border-border sticky top-0 z-50 border-b bg-white">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
    <Logo width={100} class="h-auto" />
    <button
      id="nav-toggle"
      aria-label="Toggle menu"
      aria-expanded="false"
      class="text-text block cursor-pointer border-none bg-transparent p-1 text-2xl md:hidden"
    >
      ☰
    </button>
    <div class="hidden items-center gap-6 md:flex">
      {
        navLinks.map(({ label, href }) => (
          <a
            href={href}
            aria-current={currentPath === href ? "page" : undefined}
            class:list={[
              "font-body hover:text-primary text-sm no-underline",
              currentPath === href ? "text-primary font-semibold" : "text-text",
            ]}
          >
            {label}
          </a>
        ))
      }
      {
        navActions.map(({ label, href, style }) => (
          <Button href={href} variant={style} size="sm">
            {label}
          </Button>
        ))
      }
      <DonateButton size="sm" />
    </div>
  </div>
  <nav
    id="nav-menu"
    data-open="false"
    class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-in-out data-[open=true]:grid-rows-[1fr] md:hidden"
  >
    <div class="overflow-hidden">
      <div
        class="border-border flex flex-col items-center gap-6 border-b bg-white p-6"
      >
        {
          navLinks.map(({ label, href }) => (
            <a
              href={href}
              aria-current={currentPath === href ? "page" : undefined}
              class:list={[
                "font-body hover:text-primary text-sm no-underline",
                currentPath === href
                  ? "text-primary font-semibold"
                  : "text-text",
              ]}
            >
              {label}
            </a>
          ))
        }
        {
          navActions.map(({ label, href, style }) => (
            <Button href={href} variant={style} size="sm">
              {label}
            </Button>
          ))
        }
        <DonateButton size="sm" />
      </div>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("nav-menu");

  toggle?.addEventListener("click", () => {
    const isOpen = menu?.getAttribute("data-open") === "true";
    menu?.setAttribute("data-open", String(!isOpen));
    if (toggle) {
      toggle.textContent = isOpen ? "☰" : "✕";
      toggle.setAttribute("aria-expanded", String(!isOpen));
    }
  });
</script>
