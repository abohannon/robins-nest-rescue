---
import Logo from "./Logo.astro";
import Button from "./Button.astro";
import DonateButton from "./DonateButton.astro";
import NavDropdown from "./NavDropdown.astro";
import {
  navLinks,
  navActions,
  isInHeader,
  isActiveLink,
  isExternalHref,
} from "../config/navigation";

interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;

const headerLinks = navLinks.filter(isInHeader);
---

<header class="border-border sticky top-0 z-50 border-b bg-white">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
    <Logo width={100} class="h-auto" />
    <button
      id="nav-toggle"
      aria-label="Toggle menu"
      aria-expanded="false"
      class="text-text block cursor-pointer border-none bg-transparent p-1 text-2xl lg:hidden"
    >
      ☰
    </button>
    <div class="hidden items-center gap-5 lg:flex">
      {
        headerLinks.map((link) => {
          if (link.children && link.children.length > 0) {
            return (
              <NavDropdown
                label={link.label}
                href={link.href}
                items={link.children}
                currentPath={currentPath}
              />
            );
          }
          const active = isActiveLink(link.href, currentPath);
          return (
            <a
              href={link.href}
              aria-current={active ? "page" : undefined}
              class:list={[
                "font-body hover:text-primary text-sm whitespace-nowrap no-underline",
                active ? "text-primary font-semibold" : "text-text",
              ]}
            >
              {link.label}
            </a>
          );
        })
      }
      {
        navActions.map(({ label, href, style }) => (
          <Button href={href} variant={style} size="sm">
            {label}
          </Button>
        ))
      }
      <DonateButton size="sm" />
    </div>
  </div>
  <nav
    id="nav-menu"
    data-open="false"
    class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-in-out data-[open=true]:grid-rows-[1fr] lg:hidden"
  >
    <div class="overflow-hidden">
      <div
        class="border-border flex flex-col items-stretch gap-2 border-b bg-white p-6"
      >
        {
          headerLinks.map((link) => {
            const active = isActiveLink(link.href, currentPath);
            if (link.children && link.children.length > 0) {
              return (
                <details class="group">
                  <summary
                    aria-label={`${link.label} submenu`}
                    class:list={[
                      "font-body hover:text-primary flex cursor-pointer list-none items-center justify-between text-sm no-underline",
                      active ? "text-primary font-semibold" : "text-text",
                    ]}
                  >
                    <span>{link.label}</span>
                    <svg
                      aria-hidden="true"
                      viewBox="0 0 12 12"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="ml-2 h-3 w-3 transition-transform duration-200 group-open:rotate-180"
                    >
                      <polyline points="3 5 6 8 9 5" />
                    </svg>
                  </summary>
                  <ul class="mt-2 ml-4 flex list-none flex-col gap-2 border-l border-neutral-200 p-0 pl-4">
                    <li>
                      <a
                        href={link.href}
                        aria-current={
                          currentPath === link.href ? "page" : undefined
                        }
                        class:list={[
                          "font-body hover:text-primary block text-sm no-underline",
                          currentPath === link.href
                            ? "text-primary font-semibold"
                            : "text-text",
                        ]}
                      >
                        {link.label} overview
                      </a>
                    </li>
                    {link.children.map((child) => {
                      const childActive = isActiveLink(child.href, currentPath);
                      const isExternal = isExternalHref(child.href);
                      return (
                        <li>
                          <a
                            href={child.href}
                            target={isExternal ? "_blank" : undefined}
                            rel={isExternal ? "noopener noreferrer" : undefined}
                            aria-current={childActive ? "page" : undefined}
                            class:list={[
                              "font-body hover:text-primary block text-sm no-underline",
                              childActive
                                ? "text-primary font-semibold"
                                : "text-text",
                            ]}
                          >
                            {child.label}
                          </a>
                        </li>
                      );
                    })}
                  </ul>
                </details>
              );
            }
            return (
              <a
                href={link.href}
                aria-current={active ? "page" : undefined}
                class:list={[
                  "font-body hover:text-primary text-sm no-underline",
                  active ? "text-primary font-semibold" : "text-text",
                ]}
              >
                {link.label}
              </a>
            );
          })
        }
        <div class="mt-4 flex flex-col items-center gap-4">
          {
            navActions.map(({ label, href, style }) => (
              <Button href={href} variant={style} size="sm">
                {label}
              </Button>
            ))
          }
          <DonateButton size="sm" />
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("nav-menu");

  toggle?.addEventListener("click", () => {
    const isOpen = menu?.getAttribute("data-open") === "true";
    menu?.setAttribute("data-open", String(!isOpen));
    if (toggle) {
      toggle.textContent = isOpen ? "☰" : "✕";
      toggle.setAttribute("aria-expanded", String(!isOpen));
    }
  });
</script>
