---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  source: string;
  /** ISO YYYY-MM-DD. */
  date: string;
  description?: string;
  url: string;
  image: ImageMetadata;
}

const { title, source, date, description, url, image } = Astro.props;

// Parse as UTC so the rendered day doesn't shift in negative-UTC build timezones.
const [year, month, day] = date.split("-").map(Number);
const formattedDate = new Date(
  Date.UTC(year, month - 1, day),
).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
});
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="group border-border block overflow-hidden rounded-lg border bg-white no-underline transition-shadow hover:shadow-lg"
>
  <div class="relative h-48 w-full overflow-hidden">
    <Image
      src={image}
      alt=""
      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
      widths={[400, 600]}
      sizes="(max-width: 640px) 100vw, 33vw"
    />
  </div>
  <div class="p-6">
    <p class="font-body text-text-light mb-2 text-xs tracking-wide uppercase">
      <span>{source}</span>
      <span aria-hidden="true"> · </span>
      <time datetime={date}>{formattedDate}</time>
    </p>
    <h3 class="font-heading text-text group-hover:text-primary mb-2 text-xl">
      {title}
    </h3>
    {
      description && (
        <p class="font-body text-text-light text-sm leading-relaxed">
          {description}
        </p>
      )
    }
  </div>
</a>
