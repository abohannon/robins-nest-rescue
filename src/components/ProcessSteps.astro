---
interface Step {
  title: string;
  description: string;
}

interface Props {
  heading: string;
  steps: Step[];
}

const { heading, steps } = Astro.props;
---

<section class="bg-off-white px-6 py-16">
  <div class="mx-auto max-w-5xl">
    <h2 class="font-heading text-text mb-12 text-center text-3xl">{heading}</h2>
    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      {
        steps.map((step, index) => (
          <div class="relative flex flex-col items-center text-center">
            <div class="bg-primary mb-4 flex h-12 w-12 items-center justify-center rounded-full text-lg font-semibold text-white">
              {index + 1}
            </div>
            {index < steps.length - 1 && (
              <div class="bg-border absolute top-6 left-1/2 hidden h-px w-full translate-x-1/2 -translate-y-1/2 md:block" />
            )}
            <h3 class="font-heading text-text mb-2 text-xl">{step.title}</h3>
            <p class="font-body text-text-light text-sm leading-relaxed">
              {step.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
