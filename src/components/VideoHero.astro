---
interface Props {
  headline: string;
  subtext: string;
  primaryCta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  size?: 'default' | 'tall' | 'full';
}

const { headline, subtext, primaryCta, secondaryCta, size = 'tall' } = Astro.props;

const sizeClasses: Record<'default' | 'tall' | 'full', string> = {
  default: 'py-16 md:py-24',
  tall: 'min-h-[70vh]',
  full: 'min-h-screen',
};
---

<section class:list={['relative flex items-center justify-center overflow-hidden', sizeClasses[size]]}>
  <video
    autoplay
    muted
    loop
    playsinline
    aria-hidden="true"
    poster="/videos/hero-poster.jpg"
    class="absolute inset-0 h-full w-full object-cover"
  >
    <source src="/videos/hero.webm" type="video/webm" />
    <source src="/videos/hero.mp4" type="video/mp4" />
  </video>

  <div class="absolute inset-0 bg-black/50"></div>

  <div class="relative z-10 mx-auto max-w-5xl px-6 text-center text-white">
    <h1 class="mb-4 font-heading text-3xl leading-tight md:text-5xl">
      {headline}
    </h1>
    <p class="mx-auto mb-8 max-w-xl text-lg leading-relaxed opacity-90">
      {subtext}
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a
        href={primaryCta.href}
        class="rounded-md bg-white px-8 py-3 font-body font-semibold text-primary no-underline hover:bg-off-white"
      >
        {primaryCta.label}
      </a>
      {secondaryCta && (
        <a
          href={secondaryCta.href}
          class="rounded-md border-2 border-white bg-transparent px-8 py-3 font-body font-semibold text-white no-underline hover:bg-white/10"
        >
          {secondaryCta.label}
        </a>
      )}
    </div>
  </div>
</section>
