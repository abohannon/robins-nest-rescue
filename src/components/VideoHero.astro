---
import Button from "./Button.astro";

interface Props {
  headline: string;
  subtext: string;
  primaryCta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  size?: "default" | "tall" | "full";
}

const {
  headline,
  subtext,
  primaryCta,
  secondaryCta,
  size = "tall",
} = Astro.props;

const sizeClasses: Record<"default" | "tall" | "full", string> = {
  default: "py-16 md:py-24",
  tall: "min-h-[70vh]",
  full: "min-h-screen",
};
---

<section
  class:list={[
    "relative flex items-center justify-center overflow-hidden",
    sizeClasses[size],
  ]}
>
  <video
    autoplay
    muted
    loop
    playsinline
    aria-hidden="true"
    poster="/videos/hero-poster.jpg"
    class="absolute inset-0 h-full w-full object-cover"
  >
    <source src="/videos/hero.mp4" type="video/mp4" />
  </video>

  <div class="absolute inset-0 bg-black/50"></div>

  <div class="relative z-10 mx-auto max-w-5xl px-6 text-center text-white">
    <h1 class="font-heading mb-4 text-3xl leading-tight md:text-5xl">
      {headline}
    </h1>
    <p class="mx-auto mb-8 max-w-xl text-lg leading-relaxed opacity-90">
      {subtext}
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <Button href={primaryCta.href} variant="ghost">
        {primaryCta.label}
      </Button>
      {
        secondaryCta && (
          <Button href={secondaryCta.href} variant="secondary">
            {secondaryCta.label}
          </Button>
        )
      }
    </div>
  </div>
</section>
