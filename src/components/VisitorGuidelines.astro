---
interface Props {
  variant?: "white" | "off-white";
}

const { variant = "white" } = Astro.props;
---

<section
  class:list={["px-6 py-16 md:py-24", variant === "off-white" && "bg-off-white"]}
>
  <div class="mx-auto max-w-3xl">
    <h2 class="font-heading text-primary mb-6 text-center text-3xl">
      What to Know Before You Visit
    </h2>
    <ul class="text-text space-y-4 text-lg">
      <li class="flex items-start gap-3">
        <span class="text-primary mt-1 text-xl" aria-hidden="true"
          >&#10003;</span
        >
        <span>Closed-toe shoes are required</span>
      </li>
      <li class="flex items-start gap-3">
        <span class="text-primary mt-1 text-xl" aria-hidden="true"
          >&#10003;</span
        >
        <span>Wear clothes you don't mind getting dirty</span>
      </li>
      <li class="flex items-start gap-3">
        <span class="text-primary mt-1 text-xl" aria-hidden="true"
          >&#10003;</span
        >
        <span>Dress in layers — the weather can change quickly</span>
      </li>
      <li class="flex items-start gap-3">
        <span class="text-primary mt-1 text-xl" aria-hidden="true"
          >&#10003;</span
        >
        <span
          >Feel free to bring leftover fruits or veggies for the animals</span
        >
      </li>
      <li class="flex items-start gap-3">
        <span class="text-accent-dark mt-1 text-xl" aria-hidden="true"
          >&#10007;</span
        >
        <span
          ><strong>No potatoes or onions</strong> — these are toxic to the animals</span
        >
      </li>
    </ul>
  </div>
</section>
