---
import Layout from '../components/Layout.astro';
import MissionBanner from '../components/MissionBanner.astro';
import ActionCardGrid from '../components/ActionCardGrid.astro';

const values = [
  {
    icon: '❤️',
    title: 'Compassion',
    description:
      'Every animal in our care is treated with kindness, patience, and love.',
    linkHref: '/animals',
    linkLabel: 'Meet the Animals',
  },
  {
    icon: '🤝',
    title: 'Community',
    description:
      'We partner with local organizations and volunteers to expand our impact and reach.',
    linkHref: '/events',
    linkLabel: 'See Our Events',
  },
  {
    icon: '🌱',
    title: 'Healing',
    description:
      'We believe in the extraordinary bond between animals and people — and the healing it creates.',
    linkHref: '/sanctuary',
    linkLabel: 'Visit the Sanctuary',
  },
];
---

<Layout title="About" currentPath="/about">
  <MissionBanner
    heading="About Robin's Nest Rescue"
    body="Robin's Nest Rescue was founded with a simple belief: every animal deserves safety, compassion, and a second chance. What started as a small effort has grown into a therapeutic sanctuary where rescued animals and people find healing — side by side."
  />
  <ActionCardGrid
    heading="Our Values"
    subheading="These principles guide everything we do."
    cards={values}
  />
  <MissionBanner
    heading="Join Our Mission"
    body="Whether you visit the sanctuary, attend an event, volunteer, or donate — you're making a direct impact on the lives of animals and people alike."
    cta={{ label: 'Book a Farm Tour', href: '/tours' }}
  />
</Layout>
