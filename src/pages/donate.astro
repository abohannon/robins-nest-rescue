---
import Layout from "../components/Layout.astro";
---

<Layout title="Donate" currentPath="/donate">
  <section class="mx-auto max-w-2xl px-6 py-16 text-center">
    <h1 class="font-heading mb-4 text-4xl font-bold">Support Our Mission</h1>
    <p class="text-text-light mb-8 text-lg">
      Your donation helps provide food, shelter, and medical care for the
      animals at Robin's Nest Rescue.
    </p>
    <div class="mx-auto max-w-md">
      <givebutter-widget id="LvQX0j"></givebutter-widget>
    </div>
  </section>
</Layout>
