---
import Layout from "../components/Layout.astro";
import VideoHero from "../components/VideoHero.astro";
import ProcessSteps from "../components/ProcessSteps.astro";
import MissionBanner from "../components/MissionBanner.astro";
import FeatureCardGrid from "../components/FeatureCardGrid.astro";
import animalsImage from "../assets/alpaca-smile.jpg";
import sanctuaryImage from "../assets/ranch-aerial.jpg";
import eventsImage from "../assets/rockin-robin-2023-music-1800.jpg";

const processSteps = [
  {
    title: "Rescue",
    description:
      "Animals rescued from neglect, abuse, or abandonment receive care and safety.",
  },
  {
    title: "Nurture",
    description:
      "Participants connect with rescued animals through guided, hands-on experiences.",
  },
  {
    title: "Rebuild",
    description:
      "Through patience, empathy, and connection, both animals and people rediscover trust and confidence. It's the science behind the extraordinary animal-human bond.",
  },
];

const exploreCards = [
  {
    title: "Meet the Animals",
    description:
      "Our therapists eat hay! The therapeutic, calming nature of our animal-assisted activities represents a shift from traditional counseling to nature-based healing.",
    href: "/animals",
    image: animalsImage,
  },
  {
    title: "The Sanctuary",
    description:
      "Set among open skies and quiet paths, the sanctuary offers something many have forgotten — space is to simply be.",
    href: "/sanctuary",
    image: sanctuaryImage,
  },
  {
    title: "Events",
    description:
      "From quiet visits to joyful celebrations — including our annual Rockin' Robin Music Fest — our events invite you to experience Robin's Nest firsthand.",
    href: "/events",
    image: eventsImage,
  },
];
---

<Layout title="Home" currentPath="/">
  <VideoHero
    headline="A Place Where Animals and People Heal Together"
    subtext="Robin's Nest Rescue is a sanctuary where rescued animals and people rediscover trust, connection, and healing — side by side."
    primaryCta={{ label: "Visit the Sanctuary", href: "/sanctuary" }}
    secondaryCta={{ label: "Book a Tour", href: "/tours" }}
  />
  <ProcessSteps heading="How It Works" steps={processSteps} />
  <MissionBanner
    heading="Robin's Nest isn't just an animal rescue. It's really a place where broken trust is repaired."
    body="That's why the animals matter. That's why the people matter. That's why the work matters."
    variant="highlight"
  />
  <FeatureCardGrid cards={exploreCards} />
  <MissionBanner
    heading="Whether you come to connect, to learn, or simply to spend time among the animals"
    body="Each visit offers a chance to slow down, engage, and be part of something meaningful — where healing happens naturally, side by side."
    cta={{ label: "Book a Farm Tour", href: "/tours" }}
    variant="subtle"
  />
</Layout>
