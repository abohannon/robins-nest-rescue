---
export const prerender = false;

import Layout from "../../components/Layout.astro";
import GoogleMapEmbed from "../../components/GoogleMapEmbed.astro";
import GiveButterWidget from "../../components/GiveButterWidget.astro";

const address = "16603 John Henry Lane, Ramona, CA 92065";

const fullName = Astro.url.searchParams.get("invitee_full_name");
const firstName = Astro.url.searchParams.get("invitee_first_name");
const lastName = Astro.url.searchParams.get("invitee_last_name");
const name =
  fullName ||
  [firstName, lastName].filter(Boolean).join(" ") ||
  null;
const eventTime = Astro.url.searchParams.get("event_start_time");

const heading = name ? `Almost There, ${name}!` : "Almost There!";

let subtext = "We'll see you soon at the sanctuary.";
if (eventTime) {
  const date = new Date(eventTime);
  if (!isNaN(date.getTime())) {
    const timeZone = "America/Los_Angeles";
    const formattedDate = new Intl.DateTimeFormat("en-US", {
      weekday: "long",
      month: "long",
      day: "numeric",
      timeZone,
    }).format(date);
    const formattedTime = new Intl.DateTimeFormat("en-US", {
      hour: "numeric",
      minute: "2-digit",
      timeZone,
    }).format(date);
    subtext = `We'll see you on ${formattedDate} at ${formattedTime}.`;
  }
}
---

<Layout title="Tour Confirmed" currentPath="/tours">
  <section class="px-6 py-16 md:py-24">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="font-heading text-primary mb-4 text-3xl leading-tight md:text-5xl">
        {heading}
      </h1>
      <p class="text-text-light text-lg leading-relaxed">
        {subtext}
      </p>
    </div>
  </section>

  <section class="bg-off-white px-6 py-16 md:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="font-heading text-primary mb-4 text-3xl">
        Complete Your Booking
      </h2>
      <p class="text-text-light mb-8 text-lg leading-relaxed">
        A minimum donation of $60 is required to confirm your farm tour.
        As a 501(c)(3) nonprofit, your donation is tax-deductible and goes
        directly to the care of our rescue animals.
      </p>
      <div class="mx-auto max-w-md">
        <GiveButterWidget id="gKZZE3" />
      </div>
    </div>
  </section>

  <section class="px-6 py-16 md:py-24">
    <div class="mx-auto max-w-3xl">
      <h2 class="font-heading text-primary mb-6 text-center text-3xl">
        What to Know Before You Visit
      </h2>
      <ul class="text-text space-y-4 text-lg">
        <li class="flex items-start gap-3">
          <span class="text-primary mt-1 text-xl" aria-hidden="true">&#10003;</span>
          <span>Closed-toe shoes are required</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary mt-1 text-xl" aria-hidden="true">&#10003;</span>
          <span>Wear clothes you don't mind getting dirty</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary mt-1 text-xl" aria-hidden="true">&#10003;</span>
          <span>Dress in layers — the weather can change quickly</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary mt-1 text-xl" aria-hidden="true">&#10003;</span>
          <span>Feel free to bring leftover fruits or veggies for the animals</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-accent-dark mt-1 text-xl" aria-hidden="true">&#10007;</span>
          <span><strong>No potatoes or onions</strong> — these are toxic to the animals</span>
        </li>
      </ul>
    </div>
  </section>

  <section class="px-6 py-16 md:py-24">
    <div class="mx-auto max-w-5xl">
      <h2 class="font-heading text-primary mb-4 text-center text-3xl">
        Getting Here
      </h2>
      <p class="text-text-light mb-8 text-center text-lg">
        {address}
      </p>
      <GoogleMapEmbed query={address} />
    </div>
  </section>

</Layout>
